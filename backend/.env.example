# Copy to `.env` in this folder and set real values. Never commit `.env`.

# --- Environment ---
# development (default): localhost, eager WhatsApp, faster reminder poll
# production: set on EC2 — see setup.md
# NODE_ENV=production
# HOST=0.0.0.0

# WHATSAPP_LAZY_START=true          # default false — saved sessions start on server boot
# WHATSAPP_WEB_VERSION=2.3000.1042432568-alpha  # optional pin; otherwise latest is fetched automatically
# Required on ARM Linux (Puppeteer's bundled Chrome is broken there). Install system Chromium, then:
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
# (also accepts CHROME_PATH / CHROMIUM_PATH; auto-detects common paths if unset)
# WARM_JSON_CACHE_ON_START=true        # default true when NODE_ENV=production
# MEETING_REMINDER_POLL_MS=120000      # default 120s prod, 60s dev
# BRANCH_ANALYTICS_CACHE_MS=300000
# ADMIN_AI_CONTEXT_CACHE_MS=60000

# --- Admin login (used by `/api/auth/login`) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
# Display name shown in the admin dashboard (e.g. welcome heading + AI greeting).
ADMIN_NAME=Admin

# Server port (frontend defaults to http://localhost:3334 when unset)
PORT=3334

# Live JSON data store (invoices.json, studemts.json, tasks.json, etc.).
# GET /api/st-invoices reads invoices.json via a separate direct file loader (not /api/invoices).
# Maintained on the server only — not from git. Defaults to backend/data next to server.js.
# On production, set an absolute path to your persistent volume, e.g.:
# DATA_DIR=/var/lib/beacanadian/data
# Relative values resolve from the backend folder (not the process cwd).
# DATA_DIR=data

# --- SMTP (for forgot-password OTP emails via nodemailer) ---
# Gmail example: host smtp.gmail.com, port 587, SMTP_SECURE=false, use an App Password.
# Sender display name comes from backend/profileConfig.js (DEFAULT_SMTP_FROM_NAME).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password-or-app-password

# Portal URL sent to students (no trailing slash).
# Used when sending account details on pipeline moves (Inquiry -> Application, Documentation, etc.).
# Examples:
#   Local dev:  http://localhost:3000
#   Production: https://portal.abec.lk

# Optional. Where the student should land after sign-in. Defaults to /dashboard.
# Keep it as a path only (no domain).
# STUDENT_SIGN_IN_PATH=/dashboard

# --- OpenAI (admin "AI Integrated Data Discussion" chatbot) ---
# Used by the AI chatbot on the Admin Dashboard. Get a key at
# https://platform.openai.com/api-keys. The chatbot is disabled until set.
OPENAI_API_KEY=
# Optional. Any chat-completion-capable model id. Defaults to gpt-4o-mini.
OPENAI_MODEL=gpt-4o-mini
